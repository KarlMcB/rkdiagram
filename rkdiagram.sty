%% rkdiagram.sty
%% Reed-Kellogg sentence diagram package for LaTeX
%%
%% Draws traditional Reed-Kellogg sentence diagrams using TikZ.
%% Words are marked up by grammatical role; the package computes
%% all coordinates automatically.
%%
%% Author:   (your name here)
%% Version:  0.1 (skeleton)
%% License:  LPPL 1.3c
%%
%% USAGE
%%   \usepackage{rkdiagram}
%%
%%   \begin{rksentence}
%%     \rksubject{dog}
%%     \rkverb{ran}
%%   \end{rksentence}
%%
%% See rkdiagram-doc.tex for full documentation and examples.
%% ============================================================

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{rkdiagram}[2024/01/01 v0.1 Reed-Kellogg sentence diagrams]

% ============================================================
% REQUIRED PACKAGES
% ============================================================

\RequirePackage{tikz}
\usetikzlibrary{calc}           % coordinate arithmetic
\usetikzlibrary{decorations.pathmorphing} % dotted pedestal lines

\RequirePackage{pgfkeys}         % key-value option system
\RequirePackage{etoolbox}        % \newrobustcmd, list tools
\RequirePackage{xstring}         % string tests (used in attachment parsing)

% ============================================================
% INTERNAL REGISTERS AND COUNTERS
% ============================================================

% Lengths used during layout computation
\newlength{\rk@baseline@x}      % running x cursor on the baseline
\newlength{\rk@word@wd}         % scratch: measured width of a word
\newlength{\rk@word@ht}         % scratch: measured height of a word

% Modifier-stack depth tracker per attachment slot.
% Each slot (subject, verb, object, …) gets its own counter
% recording how many modifier lines have already been dropped,
% so the next one is placed below without overlap.
% Initialised to 0 at the start of each rksentence environment.
\newlength{\rk@mod@depth@subject}
\newlength{\rk@mod@depth@verb}
\newlength{\rk@mod@depth@object}
\newlength{\rk@mod@depth@predadj}

% ============================================================
% USER-FACING CONFIGURATION  (\rksetup{key=value, ...})
% ============================================================

\pgfkeys{
  /rkdiagram/.is family,
  /rkdiagram,
  %
  % --- spacing ---
  baseline sep/.initial   = 0.45cm,   % horizontal padding between words
  modifier drop/.initial  = 0.85cm,   % vertical drop for first modifier
  modifier sep/.initial   = 0.65cm,   % extra drop per stacked modifier
  prep drop/.initial      = 1.10cm,   % extra drop before prep phrase
  stilt height/.initial   = 0.70cm,   % riser height for gerunds/infinitives
  pedestal height/.initial= 0.60cm,   % riser for subordinate-clause pedestal
  fork spread/.initial    = 0.50cm,   % vertical spread of compound fork arms
  appositive sep/.initial = 0.20cm,   % gap before appositive bracket
  %
  % --- geometry ---
  slant angle/.initial    = 60,       % degrees of modifier slant lines (from horizontal)
  divider overrun/.initial= 0.18cm,   % how far dividers extend above/below baseline
  %
  % --- style ---
  line width/.initial     = 0.4pt,
  font/.initial           = {},       % default: inherit surrounding font
  node style/.initial     = {},       % extra TikZ options applied to every word node
}

% Convenience macro so users write \rksetup{...} not \pgfkeys{/rkdiagram,...}
\newcommand{\rksetup}[1]{\pgfkeys{/rkdiagram, #1}}

% Internal accessor: \rk@get{key} expands to the value of /rkdiagram/key
\newcommand{\rk@get}[1]{\pgfkeysvalueof{/rkdiagram/#1}}

% ============================================================
% INTERNAL HELPERS
% ============================================================

% \rk@measure{text}{\lenA}{\lenB}
%   Sets \lenA = natural width of {text},
%        \lenB = total height (height + depth) of {text}
%   Both are measured in the current font.
\newcommand{\rk@measure}[3]{%
  \settowidth{#2}{\rk@get{font}#1}%
  \settoheight{#3}{\rk@get{font}#1}%
}

% \rk@halfwd{text}{\len}
%   Sets \len = 0.5 * natural width of {text}  (used to centre nodes)
\newcommand{\rk@halfwd}[2]{%
  \settowidth{#2}{\rk@get{font}#1}%
  \setlength{#2}{0.5#2}%
}

% ============================================================
% THE rksentence ENVIRONMENT
% ============================================================
%
% Everything happens inside a single tikzpicture.
% The environment:
%   1. Opens the tikzpicture and sets global line style
%   2. Resets all layout registers
%   3. Processes the word commands (which deposit TikZ draw calls)
%   4. Closes the tikzpicture
%
% NOTE: In the current skeleton the word commands are stubs that
%       print a placeholder.  Real coordinate logic is added in Step 2.

\newenvironment{rksentence}{%
  % --- reset layout registers ---
  \setlength{\rk@baseline@x}{0pt}%
  \setlength{\rk@mod@depth@subject}{0pt}%
  \setlength{\rk@mod@depth@verb}{0pt}%
  \setlength{\rk@mod@depth@object}{0pt}%
  \setlength{\rk@mod@depth@predadj}{0pt}%
  %
  % --- open TikZ picture ---
  \begin{tikzpicture}[
    line width = \rk@get{line width},
    font       = \rk@get{font},
    baseline   = (rk@origin),      % align picture baseline to LaTeX baseline
  ]%
  % invisible anchor at origin so \baseline= works
  \coordinate (rk@origin) at (0,0);
}{%
  \end{tikzpicture}%
}

% ============================================================
% MAIN-CLAUSE WORD COMMANDS  (stubs — logic added in Step 2)
% ============================================================

% \rksubject{word}
%   The grammatical subject.  Placed to the left of the subject|verb divider.
\newcommand{\rksubject}[1]{%
  % STUB: will place word node and record width
  \node[draw, dashed, inner sep=2pt, font=\tiny]
    at (\the\rk@baseline@x + 0.5cm, 0) {\textit{subj:} #1};
  \addtolength{\rk@baseline@x}{1.8cm}%
}

% \rkverb{word}
%   The main verb.  Placed to the right of the subject|verb divider.
\newcommand{\rkverb}[1]{%
  % STUB
  \node[draw, dashed, inner sep=2pt, font=\tiny]
    at (\the\rk@baseline@x + 0.5cm, 0) {\textit{verb:} #1};
  \addtolength{\rk@baseline@x}{1.8cm}%
}

% \rkobject{word}
%   The direct object.  Placed to the right of the verb|object divider.
\newcommand{\rkobject}[1]{%
  % STUB
  \node[draw, dashed, inner sep=2pt, font=\tiny]
    at (\the\rk@baseline@x + 0.5cm, 0) {\textit{obj:} #1};
  \addtolength{\rk@baseline@x}{1.8cm}%
}

% \rkpredadj{word}
%   Predicate adjective or predicate nominative.
%   Separated from verb by a backward-slanting divider (same line, angled left).
\newcommand{\rkpredadj}[1]{%
  % STUB
  \node[draw, dashed, inner sep=2pt, font=\tiny]
    at (\the\rk@baseline@x + 0.5cm, 0) {\textit{predadj:} #1};
  \addtolength{\rk@baseline@x}{1.8cm}%
}

