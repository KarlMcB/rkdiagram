\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{rkdiagram}[2026/04/24 v0.2 Reed-Kellogg sentence diagrams]

\RequirePackage{tikz}
\usetikzlibrary{calc}
\RequirePackage{pgfkeys}
\RequirePackage{etoolbox}

\newlength{\rk@baseline@x}
\newlength{\rk@word@wd}
\newlength{\rk@word@ht}
\newlength{\rk@tmp@a}
\newlength{\rk@tmp@b}
\newlength{\rk@tmp@y}
\newlength{\rk@halfsep}
\newlength{\rk@drop@len}
\newlength{\rk@slant@len}

\newlength{\rk@slot@subject@left}
\newlength{\rk@slot@subject@center}
\newlength{\rk@slot@subject@right}
\newlength{\rk@slot@verb@left}
\newlength{\rk@slot@verb@center}
\newlength{\rk@slot@verb@right}
\newlength{\rk@slot@object@left}
\newlength{\rk@slot@object@center}
\newlength{\rk@slot@object@right}
\newlength{\rk@slot@predadj@left}
\newlength{\rk@slot@predadj@center}
\newlength{\rk@slot@predadj@right}
\newlength{\rk@mod@cursor@subject}
\newlength{\rk@mod@cursor@verb}
\newlength{\rk@mod@cursor@object}
\newlength{\rk@mod@cursor@predadj}

\newlength{\rk@mod@depth@subject}
\newlength{\rk@mod@depth@verb}
\newlength{\rk@mod@depth@object}
\newlength{\rk@mod@depth@predadj}

\newlength{\rk@slot@subject@drawn}
\newlength{\rk@slot@verb@drawn}
\newlength{\rk@slot@object@drawn}
\newlength{\rk@slot@predadj@drawn}

\newlength{\rk@prep@anchor@x}
\newlength{\rk@prep@base@y}
\newlength{\rk@prep@right@x}

\pgfkeys{
  /rkdiagram/.is family,
  /rkdiagram,
  baseline sep/.initial    = 0.45cm,
  modifier drop/.initial   = 0.85cm,
  modifier sep/.initial    = 0.65cm,
  prep drop/.initial       = 1.10cm,
  stilt height/.initial    = 0.70cm,
  pedestal height/.initial = 0.60cm,
  fork spread/.initial     = 0.50cm,
  appositive sep/.initial  = 0.20cm,
  slant angle/.initial     = 60,
  divider overrun/.initial = 0.18cm,
  line width/.initial      = 0.4pt,
  font/.initial            = {},
  node style/.initial      = {},
}

\pgfkeys{
  /rkdiagram/cmd/.is family,
  /rkdiagram/cmd,
  attach/.initial = subject,
  role/.initial   = subject,
  coord/.initial  = and,
  type/.initial   = sub,
}

\newcommand{\rksetup}[1]{\pgfkeys{/rkdiagram, #1}}
\newcommand{\rk@get}[1]{\pgfkeysvalueof{/rkdiagram/#1}}
\newcommand{\rk@cmdget}[1]{\pgfkeysvalueof{/rkdiagram/cmd/#1}}
\newcommand{\rk@slotname}{}

\newcommand{\rk@measureword}[1]{%
  \setlength{\rk@word@wd}{0pt}%
  \setlength{\rk@tmp@a}{0pt}%
}

\newcommand{\rk@slotcenter}[1]{%
  \csname rk@slot@#1@center\endcsname
}

\newcommand{\rk@slotleft}[1]{%
  \csname rk@slot@#1@left\endcsname
}

\newcommand{\rk@slotright}[1]{%
  \csname rk@slot@#1@right\endcsname
}

\newcommand{\rk@depthlen}[1]{%
  \csname rk@mod@depth@#1\endcsname
}

\newcommand{\rk@modcursor}[1]{%
  \csname rk@mod@cursor@#1\endcsname
}

\newcommand{\rk@setslot}[4]{%
  \edef\rk@slotname{#1}%
  \ifdefstring{\rk@slotname}{subject}{%
    \setlength{\rk@slot@subject@left}{#2}%
    \setlength{\rk@slot@subject@center}{#3}%
    \setlength{\rk@slot@subject@right}{#4}%
    \setlength{\rk@slot@subject@drawn}{#4}%
    \setlength{\rk@mod@cursor@subject}{#2}%
  }{}%
  \ifdefstring{\rk@slotname}{verb}{%
    \setlength{\rk@slot@verb@left}{#2}%
    \setlength{\rk@slot@verb@center}{#3}%
    \setlength{\rk@slot@verb@right}{#4}%
    \setlength{\rk@slot@verb@drawn}{#4}%
    \setlength{\rk@mod@cursor@verb}{#2}%
  }{}%
  \ifdefstring{\rk@slotname}{object}{%
    \setlength{\rk@slot@object@left}{#2}%
    \setlength{\rk@slot@object@center}{#3}%
    \setlength{\rk@slot@object@right}{#4}%
    \setlength{\rk@slot@object@drawn}{#4}%
    \setlength{\rk@mod@cursor@object}{#2}%
  }{}%
  \ifdefstring{\rk@slotname}{predadj}{%
    \setlength{\rk@slot@predadj@left}{#2}%
    \setlength{\rk@slot@predadj@center}{#3}%
    \setlength{\rk@slot@predadj@right}{#4}%
    \setlength{\rk@slot@predadj@drawn}{#4}%
    \setlength{\rk@mod@cursor@predadj}{#2}%
  }{}%
}

\newcommand{\rk@slantdx}[1]{%
  \pgfmathsetlength{\rk@tmp@b}{#1/tan(\rk@get{slant angle})}%
}

\newcommand{\rk@modcoords}[1]{%
  \edef\rk@slotname{#1}%
  \setlength{\rk@drop@len}{\rk@get{modifier drop}}%
  \ifdefstring{\rk@slotname}{subject}{\addtolength{\rk@drop@len}{\rk@mod@depth@subject}}{}%
  \ifdefstring{\rk@slotname}{verb}{\addtolength{\rk@drop@len}{\rk@mod@depth@verb}}{}%
  \ifdefstring{\rk@slotname}{object}{\addtolength{\rk@drop@len}{\rk@mod@depth@object}}{}%
  \ifdefstring{\rk@slotname}{predadj}{\addtolength{\rk@drop@len}{\rk@mod@depth@predadj}}{}%
  \pgfmathsetlength{\rk@slant@len}{\rk@drop@len/tan(\rk@get{slant angle})}%
}

\newcommand{\rk@adddepth}[2]{%
  \edef\rk@slotname{#1}%
  \setlength{\rk@tmp@a}{#2}%
  \ifdefstring{\rk@slotname}{subject}{\addtolength{\rk@mod@depth@subject}{\rk@tmp@a}}{}%
  \ifdefstring{\rk@slotname}{verb}{\addtolength{\rk@mod@depth@verb}{\rk@tmp@a}}{}%
  \ifdefstring{\rk@slotname}{object}{\addtolength{\rk@mod@depth@object}{\rk@tmp@a}}{}%
  \ifdefstring{\rk@slotname}{predadj}{\addtolength{\rk@mod@depth@predadj}{\rk@tmp@a}}{}%
}

\newcommand{\rk@setmodcursor}[2]{%
  \edef\rk@slotname{#1}%
  \ifdefstring{\rk@slotname}{subject}{\setlength{\rk@mod@cursor@subject}{#2}}{}%
  \ifdefstring{\rk@slotname}{verb}{\setlength{\rk@mod@cursor@verb}{#2}}{}%
  \ifdefstring{\rk@slotname}{object}{\setlength{\rk@mod@cursor@object}{#2}}{}%
  \ifdefstring{\rk@slotname}{predadj}{\setlength{\rk@mod@cursor@predadj}{#2}}{}%
}

\newcommand{\rk@extendslotright}[2]{%
  \edef\rk@slotname{#1}%
  \ifdefstring{\rk@slotname}{subject}{%
    \ifdim#2>\rk@slot@subject@right\setlength{\rk@slot@subject@right}{#2}\fi
  }{}%
  \ifdefstring{\rk@slotname}{verb}{%
    \ifdim#2>\rk@slot@verb@right\setlength{\rk@slot@verb@right}{#2}\fi
  }{}%
  \ifdefstring{\rk@slotname}{object}{%
    \ifdim#2>\rk@slot@object@right\setlength{\rk@slot@object@right}{#2}\fi
  }{}%
  \ifdefstring{\rk@slotname}{predadj}{%
    \ifdim#2>\rk@slot@predadj@right\setlength{\rk@slot@predadj@right}{#2}\fi
  }{}%
}

\newcommand{\rk@drawmainslot}[3]{%
  \setlength{\rk@halfsep}{\rk@get{baseline sep}}%
  \divide\rk@halfsep by 2\relax
  \setlength{\rk@tmp@b}{\rk@baseline@x}%
  \addtolength{\rk@tmp@b}{\rk@halfsep}%
  \node[anchor=base west, inner sep=0pt, outer sep=0pt, \rk@get{node style}] (rk@currentword) at (\the\rk@tmp@b, 0pt) {#2};%
  \pgfextractx{\rk@tmp@y}{\pgfpointanchor{rk@currentword}{base}}%
  \pgfextractx{\rk@tmp@a}{\pgfpointanchor{rk@currentword}{east}}%
  \addtolength{\rk@tmp@a}{\rk@halfsep}%
  \pgfextracty{\rk@tmp@b}{\pgfpointanchor{rk@currentword}{north}}%
  \ifdim\rk@tmp@b>\rk@word@ht
    \setlength{\rk@word@ht}{\rk@tmp@b}%
  \fi
  \draw (\the\rk@baseline@x, 0pt) -- (\the\rk@tmp@a, 0pt);%
  \rk@setslot{#1}{\rk@baseline@x}{\rk@tmp@y}{\rk@tmp@a}%
  \setlength{\rk@baseline@x}{\rk@tmp@a}%
  #3%
}

\newcommand{\rk@drawverticaldivider}{%
  \setlength{\rk@tmp@a}{\rk@word@ht}%
  \addtolength{\rk@tmp@a}{\rk@get{divider overrun}}%
  \setlength{\rk@tmp@b}{\rk@get{divider overrun}}%
  \draw (\the\rk@baseline@x, -\the\rk@tmp@b) -- (\the\rk@baseline@x, \the\rk@tmp@a);%
}

\newcommand{\rk@drawpreddivider}{%
  \setlength{\rk@tmp@a}{\rk@word@ht}%
  \addtolength{\rk@tmp@a}{\rk@get{divider overrun}}%
  \pgfmathsetlength{\rk@tmp@b}{\rk@tmp@a/tan(\rk@get{slant angle})}%
  \setlength{\rk@tmp@y}{\rk@get{divider overrun}}%
  \draw (\the\rk@baseline@x, -\the\rk@tmp@y) -- ++(-\the\rk@tmp@b, \the\rk@tmp@a);%
}

\newenvironment{rksentence}{%
  \setlength{\rk@baseline@x}{0pt}%
  \setlength{\rk@word@ht}{2.2ex}%
  \setlength{\rk@mod@depth@subject}{0pt}%
  \setlength{\rk@mod@depth@verb}{0pt}%
  \setlength{\rk@mod@depth@object}{0pt}%
  \setlength{\rk@mod@depth@predadj}{0pt}%
  \setlength{\rk@mod@cursor@subject}{0pt}%
  \setlength{\rk@mod@cursor@verb}{0pt}%
  \setlength{\rk@mod@cursor@object}{0pt}%
  \setlength{\rk@mod@cursor@predadj}{0pt}%
  \setlength{\rk@slot@subject@drawn}{0pt}%
  \setlength{\rk@slot@verb@drawn}{0pt}%
  \setlength{\rk@slot@object@drawn}{0pt}%
  \setlength{\rk@slot@predadj@drawn}{0pt}%
  \setlength{\rk@prep@anchor@x}{0pt}%
  \setlength{\rk@prep@base@y}{0pt}%
  \setlength{\rk@prep@right@x}{0pt}%
  \begin{tikzpicture}[
    line width = \rk@get{line width},
    font       = \rk@get{font},
    baseline   = (rk@origin)
  ]%
  \coordinate (rk@origin) at (0,0);
}{%
  \end{tikzpicture}%
}

\newcommand{\rksubject}[1]{%
  \rk@drawmainslot{subject}{#1}{}%
}

\newcommand{\rkverb}[1]{%
  \rk@drawverticaldivider
  \rk@drawmainslot{verb}{#1}{}%
}

\newcommand{\rkobject}[1]{%
  \rk@drawverticaldivider
  \rk@drawmainslot{object}{#1}{}%
}

\newcommand{\rkpredadj}[1]{%
  \rk@drawpreddivider
  \rk@drawmainslot{predadj}{#1}{}%
}

\newcommand{\rk@drawmodifier}[2]{%
  \rk@modcoords{#1}%
  % Extend drawn baseline to cover the attachment point (cursor) if needed.
  % \rk@slotname is set by \rk@modcoords; cursor is the top of the slant line.
  \setlength{\rk@tmp@a}{\rk@modcursor{#1}}%
  \ifdefstring{\rk@slotname}{subject}{%
    \ifdim\rk@tmp@a>\rk@slot@subject@drawn
      \draw (\the\rk@slot@subject@drawn, 0pt) -- (\the\rk@tmp@a, 0pt);%
      \setlength{\rk@slot@subject@drawn}{\rk@tmp@a}%
    \fi
  }{}%
  \ifdefstring{\rk@slotname}{verb}{%
    \ifdim\rk@tmp@a>\rk@slot@verb@drawn
      \draw (\the\rk@slot@verb@drawn, 0pt) -- (\the\rk@tmp@a, 0pt);%
      \setlength{\rk@slot@verb@drawn}{\rk@tmp@a}%
    \fi
  }{}%
  \ifdefstring{\rk@slotname}{object}{%
    \ifdim\rk@tmp@a>\rk@slot@object@drawn
      \draw (\the\rk@slot@object@drawn, 0pt) -- (\the\rk@tmp@a, 0pt);%
      \setlength{\rk@slot@object@drawn}{\rk@tmp@a}%
    \fi
  }{}%
  \ifdefstring{\rk@slotname}{predadj}{%
    \ifdim\rk@tmp@a>\rk@slot@predadj@drawn
      \draw (\the\rk@slot@predadj@drawn, 0pt) -- (\the\rk@tmp@a, 0pt);%
      \setlength{\rk@slot@predadj@drawn}{\rk@tmp@a}%
    \fi
  }{}%
  \addtolength{\rk@tmp@a}{\rk@slant@len}%
  \node[
    rotate=-\rk@get{slant angle},
    anchor=base west,
    inner sep=0pt,
    outer sep=0pt,
    \rk@get{node style}
  ] (rk@modifierword) at (\the\rk@tmp@a, -\the\rk@drop@len) {#2};%
  \pgfextractx{\rk@tmp@b}{\pgfpointanchor{rk@modifierword}{east}}%
  \pgfextracty{\rk@tmp@y}{\pgfpointanchor{rk@modifierword}{east}}%
  \draw (\the\rk@modcursor{#1}, 0pt) -- (\the\rk@tmp@b, \the\rk@tmp@y);%
  \setlength{\rk@halfsep}{\rk@get{baseline sep}}%
  \divide\rk@halfsep by 2\relax
  \addtolength{\rk@tmp@b}{\rk@halfsep}%
  \rk@setmodcursor{#1}{\rk@tmp@b}%
  \rk@extendslotright{#1}{\rk@tmp@b}%
  \rk@adddepth{#1}{\rk@get{modifier sep}}%
}

\newcommand{\rkadj}[2][attach=subject]{%
  \pgfkeys{/rkdiagram/cmd, attach=subject, #1}%
  \expandafter\rk@drawmodifier\expandafter{\rk@cmdget{attach}}{#2}%
}

\newcommand{\rkadv}[2][attach=verb]{%
  \pgfkeys{/rkdiagram/cmd, attach=verb, #1}%
  \expandafter\rk@drawmodifier\expandafter{\rk@cmdget{attach}}{#2}%
}

\newcommand{\rkprep}[2][attach=subject]{%
  \pgfkeys{/rkdiagram/cmd, attach=subject, #1}%
  \rk@modcoords{\rk@cmdget{attach}}%
  \draw (\the\rk@slotcenter{\rk@cmdget{attach}}, 0pt) -- ++(\the\rk@slant@len, -\the\rk@drop@len);%
  \setlength{\rk@prep@anchor@x}{\rk@slotcenter{\rk@cmdget{attach}}}%
  \addtolength{\rk@prep@anchor@x}{\rk@slant@len}%
  \setlength{\rk@prep@base@y}{-\rk@drop@len}%
  \node[anchor=base west, inner sep=0pt, outer sep=0pt, \rk@get{node style}] (rk@prepword) at (\the\rk@prep@anchor@x, \the\rk@prep@base@y) {#2};%
  \pgfextractx{\rk@prep@right@x}{\pgfpointanchor{rk@prepword}{east}}%
  \setlength{\rk@halfsep}{\rk@get{baseline sep}}%
  \divide\rk@halfsep by 2\relax
  \addtolength{\rk@prep@right@x}{\rk@halfsep}%
  \draw (\the\rk@prep@anchor@x, \the\rk@prep@base@y) -- (\the\rk@prep@right@x, \the\rk@prep@base@y);%
  \rk@adddepth{\rk@cmdget{attach}}{\rk@get{modifier sep}}%
}

\newcommand{\rkprepobj}[1]{%
  \setlength{\rk@tmp@a}{\rk@word@ht}%
  \addtolength{\rk@tmp@a}{\rk@get{divider overrun}}%
  \setlength{\rk@tmp@b}{\rk@get{divider overrun}}%
  \setlength{\rk@tmp@y}{\rk@prep@base@y}%
  \addtolength{\rk@tmp@y}{-\rk@tmp@b}%
  \draw (\the\rk@prep@right@x, \the\rk@tmp@y) -- ++(0pt, \the\rk@tmp@a);%
  \setlength{\rk@tmp@a}{\rk@prep@right@x}%
  \setlength{\rk@halfsep}{\rk@get{baseline sep}}%
  \divide\rk@halfsep by 2\relax
  \setlength{\rk@tmp@a}{\rk@prep@right@x}%
  \addtolength{\rk@tmp@a}{\rk@halfsep}%
  \node[anchor=base west, inner sep=0pt, outer sep=0pt, \rk@get{node style}] (rk@prepobjword) at (\the\rk@tmp@a, \the\rk@prep@base@y) {#1};%
  \pgfextractx{\rk@tmp@b}{\pgfpointanchor{rk@prepobjword}{east}}%
  \addtolength{\rk@tmp@b}{\rk@halfsep}%
  \draw (\the\rk@prep@right@x, \the\rk@prep@base@y) -- (\the\rk@tmp@b, \the\rk@prep@base@y);%
}

\newcommand{\rkcompound}[3][coord=and]{%
  \pgfkeys{/rkdiagram/cmd, role=subject, coord=and, #1}%
  \rk@measureword{#2}%
  \setlength{\rk@tmp@a}{\rk@word@wd}%
  \rk@measureword{\rk@cmdget{coord}}%
  \setlength{\rk@tmp@b}{\rk@word@wd}%
  \rk@measureword{#3}%
  \setlength{\rk@tmp@y}{\rk@word@wd}%
  \setlength{\rk@word@wd}{\rk@tmp@a}%
  \addtolength{\rk@word@wd}{\rk@tmp@b}%
  \addtolength{\rk@word@wd}{\rk@tmp@y}%
  \addtolength{\rk@word@wd}{2\rk@get{baseline sep}}%
  \ifstrequal{\rk@cmdget{role}}{verb}{\rk@drawverticaldivider}{}%
  \rk@drawmainslot{\rk@cmdget{role}}{#2\hspace{\rk@get{baseline sep}}\rk@cmdget{coord}\hspace{\rk@get{baseline sep}}#3}{}%
}

\newcommand{\rkappositive}[2][attach=subject]{%
  \pgfkeys{/rkdiagram/cmd, attach=subject, #1}%
  \setlength{\rk@tmp@a}{\rk@slotright{\rk@cmdget{attach}}}%
  \addtolength{\rk@tmp@a}{\rk@get{appositive sep}}%
  \node[anchor=base west, inner sep=0pt, outer sep=0pt, \rk@get{node style}] (rk@appositiveword) at (\the\rk@tmp@a, 0pt) {#2};%
  \pgfextractx{\rk@tmp@b}{\pgfpointanchor{rk@appositiveword}{east}}%
  \draw (\the\rk@tmp@a, 0.2em) .. controls ++(0.2cm,0.2cm) and ++(-0.2cm,0.2cm) .. (\the\rk@tmp@b, 0.2em);%
}

\newcommand{\rkgerund}[2][role=subject]{%
  \pgfkeys{/rkdiagram/cmd, role=subject, #1}%
  \ifstrequal{\rk@cmdget{role}}{object}{\rk@drawverticaldivider}{}%
  \rk@drawmainslot{\rk@cmdget{role}}{#2}{}%
  \draw (\the\rk@slotleft{\rk@cmdget{role}}, 0pt) -- (\the\rk@slotleft{\rk@cmdget{role}}, \rk@get{stilt height});%
}

\newenvironment{rkclause}[1][type=sub, attach=verb]{%
  \begin{scope}[yshift=-1.3cm]
}{%
  \end{scope}
}

